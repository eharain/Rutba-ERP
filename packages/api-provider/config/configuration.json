  "resources": {
    "api::branch.branch": {
      "branch.find": {
        "policies": [
          {
            "key": "fullAccess",
            "grants": ["accounts_admin", "accounts_manager", "accounts_staff", "ap_admin", "ap_manager", "ap_staff", "ar_admin", "ar_manager", "ar_staff", "accounts_viewer_admin", "accounts_viewer_manager", "accounts_viewer_staff", "hr_admin", "hr_manager", "hr_staff", "sale_admin", "sale_manager", "sale_staff", "social_admin", "social_manager", "social_staff", "stock_admin", "stock_manager", "stock_staff"],
            "query": { "populate": "*", "fields": ["id", "name", "code", "address", "phone"], "pagination": { "pageSize": 100 } }
          }
        ]
      },
      "branch.findOne": {
        "policies": [
          {
            "key": "fullAccess",
            "grants": ["accounts_admin", "accounts_manager", "accounts_staff", "ap_admin", "ap_manager", "ap_staff", "ar_admin", "ar_manager", "ar_staff", "accounts_viewer_admin", "accounts_viewer_manager", "accounts_viewer_staff", "hr_admin", "hr_manager", "hr_staff", "sale_admin", "sale_manager", "sale_staff", "social_admin", "social_manager", "social_staff", "stock_admin", "stock_manager", "stock_staff"],
            "query": { "populate": "*" }
          }
        ]
      },
      "branch.create": {
        "policies": [
          {
            "key": "adminOnly",
            "grants": ["accounts_admin", "ap_admin", "ar_admin", "hr_admin", "sale_admin", "social_admin", "stock_admin"],
            "body": { "createdBy": "$user.id" }
          }
        ]
      },
      "branch.update": {
        "policies": [
          {
            "key": "adminOnly",
            "grants": ["accounts_admin", "ap_admin", "ar_admin", "hr_admin", "sale_admin", "social_admin", "stock_admin"],
            "filters": { "id": { "$eq": "$params.id" } },
            "body": { "updatedBy": "$user.id" }
          }
        ]
      },
      "branch.delete": {
        "policies": [
          {
            "key": "adminOnly",
            "grants": ["accounts_admin", "ap_admin", "ar_admin", "hr_admin", "sale_admin", "social_admin", "stock_admin"]
          }
        ]
      }
    },

    "api::brand.brand": {
      "brand.find": {
        "policies": [
          {
            "key": "fullAccess",
            "grants": ["auth_admin", "auth_manager", "auth_staff", "cms_admin", "cms_manager", "cms_staff", "sale_admin", "sale_manager", "sale_staff", "stock_admin", "stock_manager", "stock_staff", "webuser_admin", "webuser_manager", "webuser_staff", "web_user"],
            "query": { "populate": { "logo": true }, "fields": ["id", "name", "slug", "description"], "pagination": { "pageSize": 50 } }
          }
        ]
      },
      "brand.findOne": {
        "policies": [
          {
            "key": "fullAccess",
            "grants": ["auth_admin", "auth_manager", "auth_staff", "cms_admin", "cms_manager", "cms_staff", "sale_admin", "sale_manager", "sale_staff", "stock_admin", "stock_manager", "stock_staff", "webuser_admin", "webuser_manager", "webuser_staff", "web_user"],
            "query": { "populate": { "logo": true } }
          }
        ]
      },
      "brand.create": {
        "policies": [
          {
            "key": "editorAccess",
            "grants": ["auth_admin", "auth_manager", "cms_admin", "cms_manager", "cms_staff", "stock_admin", "stock_manager"],
            "body": { "createdBy": "$user.id" }
          }
        ]
      },
      "brand.update": {
        "policies": [
          {
            "key": "editorAccess",
            "grants": ["auth_admin", "auth_manager", "cms_admin", "cms_manager", "cms_staff", "stock_admin", "stock_manager"],
            "body": { "updatedBy": "$user.id" }
          }
        ]
      },
      "brand.delete": {
        "policies": [
          {
            "key": "adminOnly",
            "grants": ["auth_admin", "cms_admin", "stock_admin"]
          }
        ]
      },
      "brand.publish": {
        "policies": [
          {
            "key": "publisherAccess",
            "grants": ["auth_admin", "auth_manager", "cms_admin", "cms_manager", "stock_admin", "stock_manager"]
          }
        ]
      },
      "brand.unpublish": {
        "policies": [
          {
            "key": "publisherAccess",
            "grants": ["auth_admin", "auth_manager", "cms_admin", "cms_manager", "stock_admin", "stock_manager"]
          }
        ]
      }
    },

    "api::cash-register.cash-register": {
      "cash-register.find": {
        "policies": [
          {
            "key": "accountsAccess",
            "grants": ["accounts_admin", "accounts_manager", "accounts_staff", "accounts_viewer_admin", "accounts_viewer_manager", "accounts_viewer_staff", "sale_admin", "sale_manager", "sale_staff", "auth_admin", "auth_manager", "auth_staff"],
            "query": { "filters": { "branch": { "$eq": "$user.branch" } }, "populate": { "transactions": { "limit": 100 } }, "fields": ["id", "name", "status", "openingBalance", "currentBalance", "openedAt", "closedAt"] }
          }
        ]
      },
      "cash-register.findOne": {
        "policies": [
          {
            "key": "accountsAccess",
            "grants": ["accounts_admin", "accounts_manager", "accounts_staff", "accounts_viewer_admin", "accounts_viewer_manager", "accounts_viewer_staff", "sale_admin", "sale_manager", "sale_staff", "auth_admin", "auth_manager", "auth_staff"],
            "query": { "populate": { "transactions": true, "openedBy": true, "closedBy": true } }
          }
        ]
      },
      "cash-register.create": {
        "policies": [
          {
            "key": "adminOnly",
            "grants": ["accounts_admin", "sale_admin", "auth_admin"]
          }
        ]
      },
      "cash-register.update": {
        "policies": [
          {
            "key": "adminOnly",
            "grants": ["accounts_admin", "sale_admin", "auth_admin"]
          }
        ]
      },
      "cash-register.delete": {
        "policies": [
          {
            "key": "adminOnly",
            "grants": ["accounts_admin", "sale_admin", "auth_admin"]
          }
        ]
      },
      "cash-register.open": {
        "policies": [
          {
            "key": "openAccess",
            "grants": ["accounts_admin", "accounts_manager", "sale_admin", "sale_manager", "sale_staff", "auth_admin"],
            "body": { "openedBy": "$user.id", "openedAt": "$now" }
          }
        ]
      },
      "cash-register.close": {
        "policies": [
          {
            "key": "closeAccess",
            "grants": ["accounts_admin", "accounts_manager", "sale_admin", "sale_manager", "auth_admin"],
            "body": { "closedBy": "$user.id", "closedAt": "$now" }
          }
