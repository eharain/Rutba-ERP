    "api::cms-page.cms-page": {
      "cms-page.find": {
        "policies": [
          {
            "key": "cmsAccess",
            "grants": ["cms_admin", "cms_manager", "cms_staff"],
            "query": { "fields": ["id", "title", "slug", "content", "seo", "publishedAt", "createdAt"], "populate": { "author": { "fields": ["id", "username"] }, "media": true }, "pagination": { "pageSize": 50 } }
          },
          {
            "key": "publicRead",
            "grants": ["web_public", "web_user"],
            "query": { "filters": { "publishedAt": { "$ne": null } }, "fields": ["title", "slug", "content", "seo", "publishedAt"] }
          }
        ]
      },
      "cms-page.findOne": {
        "policies": [
          {
            "key": "cmsAccess",
            "grants": ["cms_admin", "cms_manager", "cms_staff"]
          },
          {
            "key": "publicRead",
            "grants": ["web_public", "web_user"],
            "filters": { "publishedAt": { "$ne": null } }
          }
        ]
      },
      "cms-page.create": {
        "policies": [
          {
            "key": "cmsCreate",
            "grants": ["cms_admin", "cms_manager", "cms_staff"],
            "body": { "author": "$user.id", "createdBy": "$user.id" }
          }
        ]
      },
      "cms-page.update": {
        "policies": [
          {
            "key": "cmsUpdate",
            "grants": ["cms_admin", "cms_manager", "cms_staff"],
            "body": { "updatedBy": "$user.id" }
          }
        ]
      },
      "cms-page.delete": {
        "policies": [
          {
            "key": "cmsDelete",
            "grants": ["cms_admin"]
          }
        ]
      },
      "cms-page.publish": {
        "policies": [
          {
            "key": "cmsPublish",
            "grants": ["cms_admin", "cms_manager"],
            "body": { "publishedBy": "$user.id", "publishedAt": "$now" }
          }
        ]
      },
      "cms-page.unpublish": {
        "policies": [
          {
            "key": "cmsPublish",
            "grants": ["cms_admin", "cms_manager"],
            "body": { "publishedBy": "$user.id", "publishedAt": null }
          }
        ]
      }
    },

    "api::crm-lead.crm-lead": {
      "crm-lead.find": {
        "policies": [
          {
            "key": "crmAccess",
            "grants": ["crm_admin", "crm_manager", "crm_staff", "sale_admin", "sale_manager"],
            "query": { "filters": { "assignedTo": { "$eq": "$user.id" } }, "populate": { "customer": true, "assignedTo": { "fields": ["id", "username"] } }, "fields": ["id", "name", "email", "phone", "status", "source", "notes", "createdAt"], "sort": ["createdAt:desc"], "pagination": { "pageSize": 50 } }
          }
        ]
      },
      "crm-lead.findOne": {
        "policies": [
          {
            "key": "crmAccess",
            "grants": ["crm_admin", "crm_manager", "crm_staff", "sale_admin", "sale_manager"],
            "filters": { "$or": [{ "assignedTo": "$user.id" }, { "createdBy": "$user.id" }] }
          }
        ]
      },
      "crm-lead.create": {
        "policies": [
          {
            "key": "crmCreate",
            "grants": ["crm_admin", "crm_manager", "crm_staff", "sale_admin", "sale_manager", "sale_staff", "web_public"],
            "body": { "createdBy": "$user.id", "createdAt": "$now", "status": "new" }
          }
        ]
      },
      "crm-lead.update": {
        "policies": [
          {
            "key": "crmUpdateOwn",
            "grants": ["crm_staff", "sale_staff"],
            "filters": { "createdBy": "$user.id" }
          },
          {
            "key": "crmUpdateAny",
            "grants": ["crm_admin", "crm_manager", "sale_admin", "sale_manager"]
          }
        ]
      },
      "crm-lead.delete": {
        "policies": [
          {
            "key": "crmDelete",
            "grants": ["crm_admin"]
          }
        ]
      }
    },

    "api::customer.customer": {
      "customer.find": {
        "policies": [
          {
            "key": "fullAccess",
            "grants": ["accounts_admin", "accounts_manager", "accounts_staff", "accounts_viewer_admin", "accounts_viewer_manager", "accounts_viewer_staff", "ar_admin", "ar_manager", "ar_staff", "cms_admin", "cms_manager", "cms_staff", "crm_admin", "crm_manager", "crm_staff", "delivery_admin", "delivery_manager", "delivery_staff", "order_admin", "order_manager", "order_staff", "rider_admin", "rider_manager", "rider_staff", "sale_admin", "sale_manager", "sale_staff"],
            "query": { "fields": ["id", "name", "email", "phone", "address", "totalSpent", "lastOrderAt"], "populate": { "orders": { "limit": 10 } }, "pagination": { "pageSize": 50 } }
          },
          {
            "key": "selfAccess",
            "grants": ["web_user"],
            "filters": { "id": "$user.customerId" }
          }
        ]
      },
      "customer.findOne": {
        "policies": [
          {
            "key": "fullAccess",
            "grants": ["accounts_admin", "accounts_manager", "accounts_staff", "accounts_viewer_admin", "accounts_viewer_manager", "accounts_viewer_staff", "ar_admin", "ar_manager", "ar_staff", "cms_admin", "cms_manager", "cms_staff", "crm_admin", "crm_manager", "crm_staff", "delivery_admin", "delivery_manager", "delivery_staff", "order_admin", "order_manager", "order_staff", "rider_admin", "rider_manager", "rider_staff", "sale_admin", "sale_manager", "sale_staff"]
          },
          {
            "key": "selfAccess",
            "grants": ["web_user"],
            "filters": { "id": "$user.customerId" }
          }
        ]
      },
      "customer.create": {
        "policies": [
          {
            "key": "createAccess",
            "grants": ["crm_admin", "crm_manager", "crm_staff", "sale_admin", "sale_manager", "sale_staff", "web_user", "web_public"],
            "body": { "createdBy": "$user.id", "createdAt": "$now" }
          }
        ]
      },
      "customer.update": {
        "policies": [
          {
            "key": "updateAccess",
            "grants": ["crm_admin", "crm_manager", "sale_admin", "sale_manager", "accounts_admin", "ar_admin"]
          },
          {
            "key": "selfUpdate",
            "grants": ["web_user"],
            "filters": { "id": "$user.customerId" },
            "fields": ["name", "email", "phone", "address"]
          }
        ]
      },
      "customer.delete": {
        "policies": [
          {
            "key": "adminOnly",
            "grants": ["crm_admin", "accounts_admin"]
          }
        ]
      }
    },

