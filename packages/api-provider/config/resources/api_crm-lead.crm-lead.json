{
  "uid": "api::crm-lead.crm-lead",
  "policies": {
    "crm-lead.find": {
      "policies": [
        {
          "key": "crmAccess",
          "grants": [
            "crm_admin",
            "crm_manager",
            "crm_staff",
            "sale_admin",
            "sale_manager"
          ],
          "query": {
            "filters": {
              "assignedTo": {
                "$eq": "$user.id"
              }
            },
            "populate": {
              "customer": true,
              "assignedTo": {
                "fields": [
                  "id",
                  "username"
                ]
              }
            },
            "fields": [
              "id",
              "name",
              "email",
              "phone",
              "status",
              "source",
              "notes",
              "createdAt"
            ],
            "sort": [
              "createdAt:desc"
            ],
            "pagination": {
              "pageSize": 50
            }
          }
        }
      ]
    },
    "crm-lead.findOne": {
      "policies": [
        {
          "key": "crmAccess",
          "grants": [
            "crm_admin",
            "crm_manager",
            "crm_staff",
            "sale_admin",
            "sale_manager"
          ],
          "filters": {
            "$or": [
              {
                "assignedTo": "$user.id"
              },
              {
                "createdBy": "$user.id"
              }
            ]
          }
        }
      ]
    },
    "crm-lead.create": {
      "policies": [
        {
          "key": "crmCreate",
          "grants": [
            "crm_admin",
            "crm_manager",
            "crm_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "web_public"
          ],
          "body": {
            "createdBy": "$user.id",
            "createdAt": "$now",
            "status": "new"
          }
        }
      ]
    },
    "crm-lead.update": {
      "policies": [
        {
          "key": "crmUpdateOwn",
          "grants": [
            "crm_staff",
            "sale_staff"
          ],
          "filters": {
            "createdBy": "$user.id"
          }
        },
        {
          "key": "crmUpdateAny",
          "grants": [
            "crm_admin",
            "crm_manager",
            "sale_admin",
            "sale_manager"
          ]
        }
      ]
    },
    "crm-lead.delete": {
      "policies": [
        {
          "key": "crmDelete",
          "grants": [
            "crm_admin"
          ]
        }
      ]
    }
  }
}
