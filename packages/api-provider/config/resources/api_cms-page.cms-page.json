{
  "uid": "api::cms-page.cms-page",
  "policies": {
    "cms-page.find": {
      "policies": [
        {
          "key": "cmsAccess",
          "grants": [
            "cms_admin",
            "cms_manager",
            "cms_staff"
          ],
          "query": {
            "fields": [
              "id",
              "title",
              "slug",
              "content",
              "seo",
              "publishedAt",
              "createdAt"
            ],
            "populate": {
              "author": {
                "fields": [
                  "id",
                  "username"
                ]
              },
              "media": true
            },
            "pagination": {
              "pageSize": 50
            }
          }
        },
        {
          "key": "publicRead",
          "grants": [
            "web_public",
            "web_user"
          ],
          "query": {
            "filters": {
              "publishedAt": {
                "$ne": null
              }
            },
            "fields": [
              "title",
              "slug",
              "content",
              "seo",
              "publishedAt"
            ]
          }
        }
      ]
    },
    "cms-page.findOne": {
      "policies": [
        {
          "key": "cmsAccess",
          "grants": [
            "cms_admin",
            "cms_manager",
            "cms_staff"
          ]
        },
        {
          "key": "publicRead",
          "grants": [
            "web_public",
            "web_user"
          ],
          "filters": {
            "publishedAt": {
              "$ne": null
            }
          }
        }
      ]
    },
    "cms-page.create": {
      "policies": [
        {
          "key": "cmsCreate",
          "grants": [
            "cms_admin",
            "cms_manager",
            "cms_staff"
          ],
          "body": {
            "author": "$user.id",
            "createdBy": "$user.id"
          }
        }
      ]
    },
    "cms-page.update": {
      "policies": [
        {
          "key": "cmsUpdate",
          "grants": [
            "cms_admin",
            "cms_manager",
            "cms_staff"
          ],
          "body": {
            "updatedBy": "$user.id"
          }
        }
      ]
    },
    "cms-page.delete": {
      "policies": [
        {
          "key": "cmsDelete",
          "grants": [
            "cms_admin"
          ]
        }
      ]
    },
    "cms-page.publish": {
      "policies": [
        {
          "key": "cmsPublish",
          "grants": [
            "cms_admin",
            "cms_manager"
          ],
          "body": {
            "publishedBy": "$user.id",
            "publishedAt": "$now"
          }
        }
      ]
    },
    "cms-page.unpublish": {
      "policies": [
        {
          "key": "cmsPublish",
          "grants": [
            "cms_admin",
            "cms_manager"
          ],
          "body": {
            "publishedBy": "$user.id",
            "publishedAt": null
          }
        }
      ]
    }
  }
}
