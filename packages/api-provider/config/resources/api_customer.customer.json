{
  "uid": "api::customer.customer",
  "policies": {
    "customer.find": {
      "policies": [
        {
          "key": "fullAccess",
          "grants": [
            "accounts_admin",
            "accounts_manager",
            "accounts_staff",
            "accounts_viewer_admin",
            "accounts_viewer_manager",
            "accounts_viewer_staff",
            "ar_admin",
            "ar_manager",
            "ar_staff",
            "cms_admin",
            "cms_manager",
            "cms_staff",
            "crm_admin",
            "crm_manager",
            "crm_staff",
            "delivery_admin",
            "delivery_manager",
            "delivery_staff",
            "order_admin",
            "order_manager",
            "order_staff",
            "rider_admin",
            "rider_manager",
            "rider_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff"
          ],
          "query": {
            "fields": [
              "id",
              "name",
              "email",
              "phone",
              "address",
              "totalSpent",
              "lastOrderAt"
            ],
            "populate": {
              "orders": {
                "limit": 10
              }
            },
            "pagination": {
              "pageSize": 50
            }
          }
        },
        {
          "key": "selfAccess",
          "grants": [
            "web_user"
          ],
          "filters": {
            "id": "$user.customerId"
          }
        }
      ]
    },
    "customer.findOne": {
      "policies": [
        {
          "key": "fullAccess",
          "grants": [
            "accounts_admin",
            "accounts_manager",
            "accounts_staff",
            "accounts_viewer_admin",
            "accounts_viewer_manager",
            "accounts_viewer_staff",
            "ar_admin",
            "ar_manager",
            "ar_staff",
            "cms_admin",
            "cms_manager",
            "cms_staff",
            "crm_admin",
            "crm_manager",
            "crm_staff",
            "delivery_admin",
            "delivery_manager",
            "delivery_staff",
            "order_admin",
            "order_manager",
            "order_staff",
            "rider_admin",
            "rider_manager",
            "rider_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff"
          ]
        },
        {
          "key": "selfAccess",
          "grants": [
            "web_user"
          ],
          "filters": {
            "id": "$user.customerId"
          }
        }
      ]
    },
    "customer.create": {
      "policies": [
        {
          "key": "createAccess",
          "grants": [
            "crm_admin",
            "crm_manager",
            "crm_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "web_user",
            "web_public"
          ],
          "body": {
            "createdBy": "$user.id",
            "createdAt": "$now"
          }
        }
      ]
    },
    "customer.update": {
      "policies": [
        {
          "key": "updateAccess",
          "grants": [
            "crm_admin",
            "crm_manager",
            "sale_admin",
            "sale_manager",
            "accounts_admin",
            "ar_admin"
          ]
        },
        {
          "key": "selfUpdate",
          "grants": [
            "web_user"
          ],
          "filters": {
            "id": "$user.customerId"
          },
          "fields": [
            "name",
            "email",
            "phone",
            "address"
          ]
        }
      ]
    },
    "customer.delete": {
      "policies": [
        {
          "key": "adminOnly",
          "grants": [
            "crm_admin",
            "accounts_admin"
          ]
        }
      ]
    }
  }
}
