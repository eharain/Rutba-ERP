{
  "uid": "api::branch.branch",
  "policies": {
    "branch.find": {
      "policies": [
        {
          "key": "fullAccess",
          "grants": [
            "accounts_admin",
            "accounts_manager",
            "accounts_staff",
            "ap_admin",
            "ap_manager",
            "ap_staff",
            "ar_admin",
            "ar_manager",
            "ar_staff",
            "accounts_viewer_admin",
            "accounts_viewer_manager",
            "accounts_viewer_staff",
            "hr_admin",
            "hr_manager",
            "hr_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "social_admin",
            "social_manager",
            "social_staff",
            "stock_admin",
            "stock_manager",
            "stock_staff"
          ],
          "query": {
            "populate": "*",
            "fields": [
              "id",
              "name",
              "code",
              "address",
              "phone"
            ],
            "pagination": {
              "pageSize": 100
            }
          }
        }
      ]
    },
    "branch.findOne": {
      "policies": [
        {
          "key": "fullAccess",
          "grants": [
            "accounts_admin",
            "accounts_manager",
            "accounts_staff",
            "ap_admin",
            "ap_manager",
            "ap_staff",
            "ar_admin",
            "ar_manager",
            "ar_staff",
            "accounts_viewer_admin",
            "accounts_viewer_manager",
            "accounts_viewer_staff",
            "hr_admin",
            "hr_manager",
            "hr_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "social_admin",
            "social_manager",
            "social_staff",
            "stock_admin",
            "stock_manager",
            "stock_staff"
          ],
          "query": {
            "populate": "*"
          }
        }
      ]
    },
    "branch.create": {
      "policies": [
        {
          "key": "adminOnly",
          "grants": [
            "accounts_admin",
            "ap_admin",
            "ar_admin",
            "hr_admin",
            "sale_admin",
            "social_admin",
            "stock_admin"
          ],
          "body": {
            "createdBy": "$user.id"
          }
        }
      ]
    },
    "branch.update": {
      "policies": [
        {
          "key": "adminOnly",
          "grants": [
            "accounts_admin",
            "ap_admin",
            "ar_admin",
            "hr_admin",
            "sale_admin",
            "social_admin",
            "stock_admin"
          ],
          "filters": {
            "id": {
              "$eq": "$params.id"
            }
          },
          "body": {
            "updatedBy": "$user.id"
          }
        }
      ]
    },
    "branch.delete": {
      "policies": [
        {
          "key": "adminOnly",
          "grants": [
            "accounts_admin",
            "ap_admin",
            "ar_admin",
            "hr_admin",
            "sale_admin",
            "social_admin",
            "stock_admin"
          ]
        }
      ]
    }
  }
}
