{
  "uid": "api::sale.sale",
  "policies": {
    "sale.find": {
      "policies": [
        {
          "key": "saleAccess",
          "grants": [
            "accounts_admin",
            "accounts_manager",
            "accounts_staff",
            "accounts_viewer_admin",
            "accounts_viewer_manager",
            "accounts_viewer_staff",
            "ar_admin",
            "ar_manager",
            "ar_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff"
          ],
          "query": {
            "filters": {
              "branch": {
                "$eq": "$user.branch"
              }
            },
            "fields": [
              "id",
              "invoiceNumber",
              "customer",
              "totalAmount",
              "paidAmount",
              "status",
              "soldAt"
            ],
            "populate": {
              "items": {
                "fields": [
                  "product",
                  "quantity",
                  "unitPrice",
                  "total"
                ]
              },
              "customer": {
                "fields": [
                  "id",
                  "name",
                  "phone"
                ]
              },
              "payments": true
            },
            "pagination": {
              "pageSize": 50
            },
            "sort": [
              "soldAt:desc"
            ]
          }
        }
      ]
    },
    "sale.findOne": {
      "policies": [
        {
          "key": "saleAccess",
          "grants": [
            "accounts_admin",
            "accounts_manager",
            "accounts_staff",
            "accounts_viewer_admin",
            "accounts_viewer_manager",
            "accounts_viewer_staff",
            "ar_admin",
            "ar_manager",
            "ar_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff"
          ]
        }
      ]
    },
    "sale.create": {
      "policies": [
        {
          "key": "saleCreate",
          "grants": [
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "ar_admin",
            "ar_manager"
          ],
          "body": {
            "createdBy": "$user.id",
            "soldAt": "$now",
            "branch": "$user.branch"
          }
        }
      ]
    },
    "sale.update": {
      "policies": [
        {
          "key": "saleUpdate",
          "grants": [
            "sale_admin",
            "sale_manager",
            "ar_admin",
            "ar_manager"
          ]
        }
      ]
    },
    "sale.cancel": {
      "policies": [
        {
          "key": "saleCancel",
          "grants": [
            "sale_admin",
            "sale_manager",
            "ar_admin"
          ],
          "body": {
            "cancelledBy": "$user.id",
            "cancelledAt": "$now",
            "status": "cancelled"
          }
        }
      ]
    },
    "sale.delete": {
      "policies": [
        {
          "key": "saleDelete",
          "grants": [
            "sale_admin",
            "ar_admin"
          ]
        }
      ]
    }
  }
}
