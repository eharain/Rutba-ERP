{
  "uid": "api::sale-order.sale-order",
  "policies": {
    "sale-order.find": {
      "policies": [
        {
          "key": "orderAccess",
          "grants": [
            "order_admin",
            "order_manager",
            "order_staff",
            "delivery_admin",
            "delivery_manager",
            "delivery_staff",
            "rider_admin",
            "rider_manager",
            "rider_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "webuser_admin",
            "webuser_manager",
            "webuser_staff"
          ],
          "query": {
            "fields": [
              "id",
              "orderNumber",
              "customer",
              "items",
              "subtotal",
              "shippingCost",
              "total",
              "status",
              "paymentStatus",
              "createdAt"
            ],
            "populate": {
              "customer": {
                "fields": [
                  "id",
                  "name",
                  "address",
                  "phone"
                ]
              },
              "delivery": {
                "fields": [
                  "rider",
                  "trackingNumber",
                  "status"
                ]
              }
            },
            "pagination": {
              "pageSize": 50
            },
            "sort": [
              "createdAt:desc"
            ]
          }
        },
        {
          "key": "selfAccess",
          "grants": [
            "web_user"
          ],
          "filters": {
            "customer.id": "$user.customerId"
          }
        }
      ]
    },
    "sale-order.findOne": {
      "policies": [
        {
          "key": "orderAccess",
          "grants": [
            "order_admin",
            "order_manager",
            "order_staff",
            "delivery_admin",
            "delivery_manager",
            "delivery_staff",
            "rider_admin",
            "rider_manager",
            "rider_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "webuser_admin",
            "webuser_manager",
            "webuser_staff"
          ]
        },
        {
          "key": "selfAccess",
          "grants": [
            "web_user"
          ],
          "filters": {
            "customer.id": "$user.customerId"
          }
        }
      ]
    },
    "sale-order.create": {
      "policies": [
        {
          "key": "orderCreate",
          "grants": [
            "order_admin",
            "order_manager",
            "order_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff"
          ],
          "body": {
            "createdBy": "$user.id",
            "status": "pending",
            "paymentStatus": "unpaid"
          }
        },
        {
          "key": "publicCheckout",
          "grants": [
            "web_public",
            "web_user"
          ],
          "body": {
            "source": "web",
            "status": "pending_confirmation"
          }
        }
      ]
    },
    "sale-order.update": {
      "policies": [
        {
          "key": "orderUpdate",
          "grants": [
            "order_admin",
            "order_manager",
            "delivery_admin",
            "delivery_manager",
            "sale_admin",
            "sale_manager"
          ]
        }
      ]
    },
    "sale-order.tracking": {
      "policies": [
        {
          "key": "publicTracking",
          "grants": [
            "web_public",
            "web_user",
            "delivery_staff",
            "rider_staff"
          ],
          "fields": [
            "orderNumber",
            "delivery.status",
            "delivery.trackingNumber",
            "delivery.estimatedDelivery",
            "currentLocation"
          ]
        }
      ]
    },
    "sale-order.delete": {
      "policies": [
        {
          "key": "orderDelete",
          "grants": [
            "order_admin",
            "sale_admin"
          ]
        }
      ]
    }
  }
}
