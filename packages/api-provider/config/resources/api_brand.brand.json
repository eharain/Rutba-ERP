{
  "uid": "api::brand.brand",
  "policies": {
    "brand.find": {
      "policies": [
        {
          "key": "fullAccess",
          "grants": [
            "auth_admin",
            "auth_manager",
            "auth_staff",
            "cms_admin",
            "cms_manager",
            "cms_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "stock_admin",
            "stock_manager",
            "stock_staff",
            "webuser_admin",
            "webuser_manager",
            "webuser_staff",
            "web_user"
          ],
          "query": {
            "populate": {
              "logo": true
            },
            "fields": [
              "id",
              "name",
              "slug",
              "description"
            ],
            "pagination": {
              "pageSize": 50
            }
          }
        }
      ]
    },
    "brand.findOne": {
      "policies": [
        {
          "key": "fullAccess",
          "grants": [
            "auth_admin",
            "auth_manager",
            "auth_staff",
            "cms_admin",
            "cms_manager",
            "cms_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "stock_admin",
            "stock_manager",
            "stock_staff",
            "webuser_admin",
            "webuser_manager",
            "webuser_staff",
            "web_user"
          ],
          "query": {
            "populate": {
              "logo": true
            }
          }
        }
      ]
    },
    "brand.create": {
      "policies": [
        {
          "key": "editorAccess",
          "grants": [
            "auth_admin",
            "auth_manager",
            "cms_admin",
            "cms_manager",
            "cms_staff",
            "stock_admin",
            "stock_manager"
          ],
          "body": {
            "createdBy": "$user.id"
          }
        }
      ]
    },
    "brand.update": {
      "policies": [
        {
          "key": "editorAccess",
          "grants": [
            "auth_admin",
            "auth_manager",
            "cms_admin",
            "cms_manager",
            "cms_staff",
            "stock_admin",
            "stock_manager"
          ],
          "body": {
            "updatedBy": "$user.id"
          }
        }
      ]
    },
    "brand.delete": {
      "policies": [
        {
          "key": "adminOnly",
          "grants": [
            "auth_admin",
            "cms_admin",
            "stock_admin"
          ]
        }
      ]
    },
    "brand.publish": {
      "policies": [
        {
          "key": "publisherAccess",
          "grants": [
            "auth_admin",
            "auth_manager",
            "cms_admin",
            "cms_manager",
            "stock_admin",
            "stock_manager"
          ]
        }
      ]
    },
    "brand.unpublish": {
      "policies": [
        {
          "key": "publisherAccess",
          "grants": [
            "auth_admin",
            "auth_manager",
            "cms_admin",
            "cms_manager",
            "stock_admin",
            "stock_manager"
          ]
        }
      ]
    }
  }
}
