{
  "uid": "api::stock-item.stock-item",
  "policies": {
    "stock-item.find": {
      "policies": [
        {
          "key": "stockAccess",
          "grants": [
            "accounts_admin",
            "accounts_manager",
            "accounts_staff",
            "accounts_viewer_admin",
            "accounts_viewer_manager",
            "accounts_viewer_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "stock_admin",
            "stock_manager",
            "stock_staff"
          ],
          "query": {
            "filters": {
              "branch": {
                "$eq": "$user.branch"
              }
            },
            "fields": [
              "id",
              "product",
              "sku",
              "barcode",
              "quantity",
              "reservedQuantity",
              "availableQuantity",
              "location",
              "batchNumber",
              "expiryDate"
            ],
            "populate": {
              "product": {
                "fields": [
                  "id",
                  "name",
                  "price"
                ]
              }
            },
            "pagination": {
              "pageSize": 50
            }
          }
        }
      ]
    },
    "stock-item.findOne": {
      "policies": [
        {
          "key": "stockAccess",
          "grants": [
            "accounts_admin",
            "accounts_manager",
            "accounts_staff",
            "accounts_viewer_admin",
            "accounts_viewer_manager",
            "accounts_viewer_staff",
            "sale_admin",
            "sale_manager",
            "sale_staff",
            "stock_admin",
            "stock_manager",
            "stock_staff"
          ]
        }
      ]
    },
    "stock-item.adjust": {
      "policies": [
        {
          "key": "stockAdjust",
          "grants": [
            "stock_admin",
            "stock_manager"
          ],
          "body": {
            "adjustedBy": "$user.id",
            "adjustedAt": "$now"
          }
        }
      ]
    },
    "stock-item.transfer": {
      "policies": [
        {
          "key": "stockTransfer",
          "grants": [
            "stock_admin",
            "stock_manager"
          ],
          "body": {
            "transferBy": "$user.id",
            "transferAt": "$now"
          }
        }
      ]
    },
    "stock-item.receive": {
      "policies": [
        {
          "key": "stockReceive",
          "grants": [
            "stock_admin",
            "stock_manager",
            "stock_staff"
          ],
          "body": {
            "receivedBy": "$user.id",
            "receivedAt": "$now"
          }
        }
      ]
    }
  }
}
