{
  "name": "@rutba/pos-shared",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "validate:exports": "node ./scripts/validate-exports.mjs",
    "validate": "npm run validate:exports",
    "build": "npm run validate"
  },
  "dependencies": {
    "@rutba/api-provider": "1.0.0"
  },
  "exports": {
    "./lib/*": [
      "./lib/*",
      "./lib/*.js"
    ],
    "./context/*": [
      "./context/*",
      "./context/*.js"
    ],
    "./components/*": [
      "./components/*",
      "./components/*.js"
    ],
    "./domain/*": [
      "./context/domain/*",
      "./context/domain/*.js"
    ],
    "./styles/*": "./styles/*"
  }
}
