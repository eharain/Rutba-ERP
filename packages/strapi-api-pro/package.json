{
  "name": "strapi-api-pro",
  "version": "0.0.1-alpha",
  "description": "API interface builder and policy orchestration plugin for Strapi 5",
  "license": "MIT",
  "main": "./dist/server/index.js",
  "exports": {
    ".": {
      "source": "./server/src/index.js",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./strapi-admin": {
      "source": "./admin/src/index.js",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "source": "./server/src/index.js",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "strapi-plugin build && node scripts/ensure-dist-package-json.cjs",
    "watch": "strapi-plugin watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@strapi/strapi": "^5.0.0",
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "^5.0.0",
    "rimraf": "^5.0.0"
  },
  "strapi": {
    "name": "api-pro",
    "displayName": "Strapi API Pro",
    "description": "Build API interfaces from recordings/content-types with role-aware policies",
    "kind": "plugin",
    "required": false
  },
  "files": [
    "admin/",
    "server/",
    "strapi-server.js",
    "strapi-admin.js"
  ]
}