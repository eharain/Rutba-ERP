# ============================================================
# Rutba ERP — Environment Configuration
# ============================================================
#
#  TWO LOADING MODES
#  ─────────────────
#  The env system (scripts/load-env.js, scripts/generate-docker-env.js)
#  operates in one of two modes, chosen automatically:
#
#  ┌─────────────┬─────────────────────────────────────────────┐
#  │ File mode   │ .env file EXISTS at repo root               │
#  │ (default)   │ 1. .env  →  selects ENVIRONMENT             │
#  │             │ 2. .env.<ENVIRONMENT>  →  full config        │
#  │             │ File values override process.env             │
#  ├─────────────┼─────────────────────────────────────────────┤
#  │ Env-var mode│ NO .env file (Docker / CI)                  │
#  │             │ ENVIRONMENT from process.env (default: dev)  │
#  │             │ All config from process.env                  │
#  │             │ Only NEXT_PUBLIC_* and PREFIX__* collected    │
#  └─────────────┴─────────────────────────────────────────────┘
#
#  VARIABLE SPLITTING
#  ──────────────────
#  scripts/load-env.js reads variables and splits them into two types:
#
#    GLOBAL — no __ delimiter → injected into EVERY app
#      NEXT_PUBLIC_API_URL=http://localhost:4010/api/
#
#    APP-SPECIFIC — WORKSPACE_NAME__VARNAME → prefix + __
#      stripped, injected only into that app
#      POS_AUTH__PORT=4003        →  PORT=4003      (pos-auth only)
#      RUTBA_WEB__NEXTAUTH_SECRET=abc  →  NEXTAUTH_SECRET=abc  (rutba-web only)
#
#  Prefix = workspace directory name, uppercased, hyphens → _
#    pos-strapi      → POS_STRAPI__
#    pos-auth        → POS_AUTH__
#    rutba-web       → RUTBA_WEB__
#    rutba-web-user  → RUTBA_WEB_USER__
#    rutba-rider     → RUTBA_RIDER__
#    rutba-social    → RUTBA_SOCIAL__
#    rutba-ess       → RUTBA_ESS__
#    rutba-manufacturing → RUTBA_MANUFACTURING__
#    rutba-marketplace   → RUTBA_MARKETPLACE__
#
#  VALIDATION
#  ──────────
#  Required variables are defined in scripts/env-config.js.
#  The loader will:
#    - ERROR and abort on missing critical variables (severity: 'error')
#    - WARN but continue on missing optional variables (severity: 'warn')
#
#  The target app is auto-detected from --workspace= or --prefix
#  in the command — no redundant app argument needed:
#    "dev:auth": "node scripts/load-env.js -- npm run dev --workspace=pos-auth"
#
#  CORS: Strapi receives a CORS_ORIGINS env var auto-computed
#        from every URL value in the env file. No manual list.
#
#  PORT RESOLUTION
#  ───────────────
#  PORT is only set when explicitly configured:
#    1. process.env.PORT (platform/host override — ALWAYS wins)
#    2. PREFIX__PORT in env file (e.g. POS_AUTH__PORT=4003)
#
#  No PORT is auto-derived from URLs. If neither is set, the app
#  uses its own default.
#
#  On managed platforms (Hostinger, Railway, Azure App Service) the
#  platform sets PORT automatically. The loader respects it.
#
#  STRAPI BEHIND A REVERSE PROXY
#  ─────────────────────────────
#  When pos-strapi is fronted by nginx / Caddy / Traefik with TLS termination
#  (e.g. api.rutba.pk → http://localhost:4010), set BOTH:
#
#    POS_STRAPI__PUBLIC_URL=https://api.rutba.pk
#    POS_STRAPI__IS_PROXIED=true
#
#  Without these, password-reset / email-confirmation links and absolute
#  upload URLs are built from the internal http://localhost:4010 host and
#  break the moment they leave the network.
# ============================================================

ENVIRONMENT=development

# ============================================================
#  SOCIAL MEDIA INTEGRATION (rutba-social → pos-strapi)
#  ─────────────────────────────────────────────────────────
#  OAuth client credentials per platform. Set the ones you use; accounts can
#  also be connected by pasting a long-lived access token in the UI (no client
#  id/secret needed for that path). PUBLIC_URL must be the https origin the
#  providers redirect back to — callback is <PUBLIC_URL>/api/social-accounts/oauth/callback.
#
#  In each provider's app dashboard, whitelist that exact callback URL and set
#  the webhook URL to <PUBLIC_URL>/api/social-posts/webhook/<platform> using the
#  verify token below.
# ============================================================
# POS_STRAPI__SOCIAL_PUBLIC_URL=https://api.rutba.pk
# POS_STRAPI__SOCIAL_WEBHOOK_VERIFY_TOKEN=change-me
# POS_STRAPI__SOCIAL_GRAPH_VERSION=v21.0
#
# Facebook Pages + Instagram (one Meta app powers both)
# POS_STRAPI__SOCIAL_FACEBOOK_CLIENT_ID=
# POS_STRAPI__SOCIAL_FACEBOOK_CLIENT_SECRET=
# POS_STRAPI__SOCIAL_INSTAGRAM_CLIENT_ID=        # defaults to the Facebook app id
# POS_STRAPI__SOCIAL_INSTAGRAM_CLIENT_SECRET=    # defaults to the Facebook app secret
#
# X / Twitter (OAuth2 + PKCE; requires a paid tier for reply/search)
# POS_STRAPI__SOCIAL_X_CLIENT_ID=
# POS_STRAPI__SOCIAL_X_CLIENT_SECRET=
#
# TikTok (Content Posting API; PULL_FROM_URL needs a verified domain)
# POS_STRAPI__SOCIAL_TIKTOK_CLIENT_KEY=
# POS_STRAPI__SOCIAL_TIKTOK_CLIENT_SECRET=
#
# YouTube (Google OAuth2; video uploads cost ~1600 quota units each)
# POS_STRAPI__SOCIAL_YOUTUBE_CLIENT_ID=          # or SOCIAL_GOOGLE_CLIENT_ID
# POS_STRAPI__SOCIAL_YOUTUBE_CLIENT_SECRET=      # or SOCIAL_GOOGLE_CLIENT_SECRET
#
# Background jobs (defaults shown). Disable cron to publish only on demand.
# POS_STRAPI__SOCIAL_CRON_ENABLED=true
# POS_STRAPI__SOCIAL_CRON_PUBLISH_RULE=* * * * *
# POS_STRAPI__SOCIAL_CRON_SYNC_RULE=*/10 * * * *
# POS_STRAPI__SOCIAL_CRON_REFRESH_RULE=0 */6 * * *

# ============================================================
#  MARKETPLACE INTEGRATION (rutba-marketplace app + worker)
#  ─────────────────────────────────────────────────────────
#  The engine runs in a STANDALONE worker process
#  (npm run worker:marketplace), separate from the Next UI — sync
#  runs can take arbitrary time. Data lives in Strapi; the worker
#  reaches it with a FULL-ACCESS API token (api-pro skips API-token
#  requests). PUBLIC_URL is the app's https origin — the Daraz OAuth
#  callback is <PUBLIC_URL>/api/oauth/callback (whitelist it in the
#  Daraz app dashboard). Per-account keys can also be entered in the
#  UI; these app-level keys are the default.
# ============================================================
NEXT_PUBLIC_MARKETPLACE_URL=http://localhost:4016
RUTBA_MARKETPLACE__PORT=4016
RUTBA_MARKETPLACE__STRAPI_API_URL=http://127.0.0.1:4010/api
RUTBA_MARKETPLACE__STRAPI_SERVICE_TOKEN=
RUTBA_MARKETPLACE__PUBLIC_URL=http://localhost:4016
RUTBA_MARKETPLACE__WORKER_ENABLED=true
RUTBA_MARKETPLACE__JOBS_BACKEND=inproc
RUTBA_MARKETPLACE__CRON_ORDERS_RULE=*/15 * * * *
RUTBA_MARKETPLACE__CRON_INVENTORY_RULE=*/30 * * * *
RUTBA_MARKETPLACE__CRON_REFRESH_RULE=0 */4 * * *
RUTBA_MARKETPLACE__DARAZ_APP_KEY=
RUTBA_MARKETPLACE__DARAZ_APP_SECRET=
RUTBA_MARKETPLACE__DARAZ_REGION=pk
