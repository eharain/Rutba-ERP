{
  "kind": "collectionType",
  "collectionName": "cms_pages",
  "info": {
    "singularName": "cms-page",
    "pluralName": "cms-pages",
    "displayName": "CMS Page",
    "description": "Static pages and blog posts for the public website"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "enable_contact_form": {
      "type": "boolean",
      "default": false
    },
    "excerpt": {
      "type": "richtext"
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "featured_image_show_overlay": {
      "type": "boolean",
      "default": true
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "page_type": {
      "type": "enumeration",
      "enum": [
        "shop",
        "blog",
        "news",
        "info",
        "page"
      ],
      "default": "shop"
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "product_groups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-group.product-group"
    },
    "related_pages": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cms-page.cms-page"
    },
    "page_groups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cms-page-group.cms-page-group",
      "inversedBy": "displayed_on_pages"
    },
    "member_page_groups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cms-page-group.cms-page-group",
      "mappedBy": "pages"
    },
    "menus": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cms-menu.cms-menu",
      "mappedBy": "pages"
    },
    "owners": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "hero_product_groups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-group.product-group"
    },
    "brand_groups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::brand-group.brand-group"
    },
    "category_groups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category-group.category-group"
    },
    "footer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::cms-footer.cms-footer"
    },
    "background_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "offers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sale-offer.sale-offer",
      "mappedBy": "cms_pages"
    },
    "delivery_methods": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::delivery-method.delivery-method",
      "mappedBy": "cms_pages"
    },
    "excerpt_priority": {
      "type": "integer",
      "default": 10
    },
    "featured_image_priority": {
      "type": "integer",
      "default": 0
    },
    "content_priority": {
      "type": "integer",
      "default": 20
    },
    "product_groups_priority": {
      "type": "integer",
      "default": 30
    },
    "gallery_priority": {
      "type": "integer",
      "default": 40
    },
    "related_pages_priority": {
      "type": "integer",
      "default": 50
    },
    "page_groups_priority": {
      "type": "integer",
      "default": 45
    },
    "seo_meta": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::seo-meta.seo-meta",
      "mappedBy": "cms_page"
    }
  }
}
