{
  "kind": "collectionType",
  "collectionName": "addresses",
  "info": {
    "singularName": "address",
    "pluralName": "addresses",
    "displayName": "Address",
    "description": "Shipping / billing address tied to a person. Multi-row per person with one default. Optional recipient overrides for gift orders."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "label": {
      "type": "string"
    },
    "line1": {
      "type": "string"
    },
    "line2": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "zip_code": {
      "type": "string"
    },
    "is_default": {
      "type": "boolean",
      "default": false
    },
    "archived_at": {
      "type": "datetime"
    },
    "recipient_name": {
      "type": "string"
    },
    "recipient_phone": {
      "type": "string"
    },
    "person": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::person.person",
      "inversedBy": "addresses"
    }
  }
}
