{
  "kind": "collectionType",
  "collectionName": "cms_menus",
  "info": {
    "singularName": "cms-menu",
    "pluralName": "cms-menus",
    "displayName": "CMS Menu",
    "description": "CMS-driven navigation menus (top / side / footer) for the storefront"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "position": {
      "type": "enumeration",
      "enum": [
        "top",
        "side",
        "footer"
      ],
      "default": "top"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::cms-menu-item.cms-menu-item",
      "mappedBy": "menu"
    },
    "pages": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cms-page.cms-page",
      "inversedBy": "menus"
    }
  }
}
