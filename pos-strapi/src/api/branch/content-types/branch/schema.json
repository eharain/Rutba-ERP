{
  "kind": "collectionType",
  "collectionName": "branches",
  "info": {
    "singularName": "branch",
    "pluralName": "branches",
    "displayName": "Branch"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {

    "companyName": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "web": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "watsapp": {
      "type": "string"
    },

    "po_prefix": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "town": {
      "type": "string"
    },
    "tax_rate": {
      "type": "decimal",
      "default": 0
    },
    "city": {
      "type": "string"
    },
    "desks": {
      "type": "component",
      "component": "pos.sales-desks",
      "repeatable": true
    },
    "location_code": {
      "type": "string"
    },
    "location_type": {
      "type": "enumeration",
      "enum": [
        "warehouse",
        "store",
        "transit",
        "virtual",
        "supplier",
        "customer"
      ],
      "default": "warehouse"
    },
    "is_default_location": {
      "type": "boolean",
      "default": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::stock-item.stock-item",
      "mappedBy": "branch"
    },
    "locations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::storage-location.storage-location",
      "mappedBy": "branch"
    },
    "payments": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::payment.payment",
      "inversedBy": "branches"
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "inversedBy": "branches"
    },
    "purchase_returns": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::purchase-return.purchase-return",
      "inversedBy": "branches"
    },
    "sales": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sale.sale",
      "inversedBy": "branches"
    },
    "sale_returns": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sale-return.sale-return",
      "inversedBy": "branches"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "youtube": {
      "type": "string"
    },
    "tiktok": {
      "type": "string"
    },
    "instagram": {
      "type": "string"
    },
    "twitter": {
      "type": "string"
    },
    "currency": {
      "type": "relation",
      "target": "api::currency.currency",
      "relation": "oneToOne"
    },
    "printSettings": {
      "type": "json"
    },
    "invoiceTerms": {
      "type": "richtext"
    }
  }
}
