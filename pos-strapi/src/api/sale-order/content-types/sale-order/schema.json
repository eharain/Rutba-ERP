{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "sale-order",
    "pluralName": "sale-orders",
    "displayName": "Sale Order",
    "description": "Customer sale order for checkout, fulfillment, and delivery workflows"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "order_id": {
      "type": "uid",
      "required": true
    },
    "customer_person": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::person.person"
    },
    "delivery_address": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::address.address"
    },
    "delivery_snapshot": {
      "type": "json"
    },
    "products": {
      "type": "component",
      "repeatable": false,
      "component": "order.order-products"
    },
    "shipping_id": {
      "type": "string"
    },
    "rate_id": {
      "type": "string"
    },
    "shipping_name": {
      "type": "string"
    },
    "stripe_id": {
      "type": "string"
    },
    "stripe_url": {
      "type": "text"
    },
    "stripe_request": {
      "type": "json"
    },
    "stripe_response_webhook": {
      "type": "json"
    },
    "subtotal": {
      "type": "decimal"
    },
    "shipping_price": {
      "type": "decimal"
    },
    "total": {
      "type": "decimal"
    },
    "payment_status": {
      "type": "string",
      "required": true
    },
    "shipping_label": {
      "type": "json"
    },
    "tracking_url": {
      "type": "text"
    },
    "label_image": {
      "type": "text"
    },
    "tracking_code": {
      "type": "string"
    },
    "order_secret": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "owners": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "PENDING_PAYMENT",
        "PAYMENT_CONFIRMED",
        "PREPARING",
        "AWAITING_PICKUP",
        "OUT_FOR_DELIVERY",
        "DELIVERED",
        "CANCELLED",
        "FAILED_DELIVERY",
        "RETURN_REQUESTED",
        "RETURN_IN_TRANSIT",
        "RETURNED",
        "REFUND_INITIATED",
        "REFUNDED"
      ],
      "default": "PENDING_PAYMENT"
    },
    "stage_key": { "type": "string" },
    "label_url": { "type": "text" },
    "label_generated_at": { "type": "datetime" },
    "return_label_url": { "type": "text" },
    "return_label_generated_at": { "type": "datetime" },
    "return_method": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::return-method.return-method"
    },
    "delivery_method": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::delivery-method.delivery-method"
    },
    "delivery_zone": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::delivery-zone.delivery-zone"
    },
    "assigned_rider": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::rider.rider"
    },
    "assignee": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::hr-employee.hr-employee"
    },
    "delivery_cost": { "type": "decimal" },
    "delivery_cost_breakdown": { "type": "json" },
    "estimated_delivery_time": { "type": "datetime" },
    "actual_delivery_time": { "type": "datetime" },
    "rider_notes": { "type": "text" },
    "original_subtotal": { "type": "decimal" },
    "savings": { "type": "decimal" },
    "delivery_offers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::delivery-offer.delivery-offer",
      "mappedBy": "order"
    },
    "order_messages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-message.order-message",
      "mappedBy": "order"
    },
    "payment_method": {
      "type": "enumeration",
      "enum": [
        "cod",
        "card",
        "bank_transfer",
        "mobile_wallet",
        "online_gateway"
      ],
      "default": "cod"
    },
    "paid_amount": {
      "type": "decimal"
    },
    "payment_collected_at": {
      "type": "datetime"
    },
    "payment_collected_by_rider": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::rider.rider"
    },
    "payment_collected_by_note": {
      "type": "string"
    },
    "payment_verification_status": {
      "type": "enumeration",
      "enum": [
        "unverified",
        "verified",
        "disputed"
      ],
      "default": "unverified"
    },
    "payment_verified_at": {
      "type": "datetime"
    },
    "payment_verified_by": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "payment_verification_notes": {
      "type": "text"
    },
    "pending_cost_change": {
      "type": "json"
    },
    "customer_confirmed_at": {
      "type": "datetime"
    },
    "customer_confirmed_via": {
      "type": "enumeration",
      "enum": ["email", "phone", "whatsapp", "in_person"]
    },
    "customer_confirmed_by": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "customer_confirmation_notes": {
      "type": "text"
    },
    "channel": {
      "type": "enumeration",
      "enum": [
        "web",
        "pos",
        "manual",
        "daraz",
        "amazon",
        "shopify"
      ],
      "default": "web"
    },
    "external_order_id": {
      "type": "string"
    },
    "external_order_number": {
      "type": "string"
    },
    "external_vendor_id": {
      "type": "string"
    },
    "channel_meta": {
      "type": "json"
    },
    "marketplace_account": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::marketplace-account.marketplace-account"
    }
  }
}
