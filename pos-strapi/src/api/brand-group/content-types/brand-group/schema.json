{
  "kind": "collectionType",
  "collectionName": "brand_groups",
  "info": {
    "singularName": "brand-group",
    "pluralName": "brand-groups",
    "displayName": "Brand Group",
    "description": "Groups of brands for display on CMS pages"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "brands": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::brand.brand"
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    }
  }
}
