{
  "kind": "collectionType",
  "collectionName": "stock_items",
  "info": {
    "singularName": "stock-item",
    "pluralName": "stock-items",
    "displayName": "Stock Item"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": false
    },
    "sku": {
      "type": "string"
    },
    "barcode": {
      "type": "string",
      "unique": true
    },
    "status": {
      "type": "enumeration",
      "default": "InStock",
      "enum": [
        "Received",
        "InStock",
        "Reserved",
        "Sold",
        "Returned",
        "ReturnedDamaged",
        "ReturnedToSupplier",
        "Damaged",
        "Lost",
        "Expired",
        "Transferred",
        "Reduced"
      ]
    },
    "sellable_units": {
      "type": "decimal",
      "default": 1
    },
    "units_sold": {
      "type": "decimal",
      "default": 0
    },
    "sold_units": {
      "type": "integer",
      "default": 0
    },
    "cost_price": {
      "type": "decimal"
    },
    "selling_price": {
      "type": "decimal"
    },
    "offer_price": {
      "type": "decimal"
    },
    "discount": {
      "type": "decimal",
      "default": 0
    },

    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "items"
    },
    "purchase_item": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::purchase-item.purchase-item",
      "inversedBy": "items"
    },
    "sale_items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sale-item.sale-item",
      "inversedBy": "items"
    },
    "sale_return_items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sale-return-item.sale-return-item",
      "inversedBy": "items"
    },
    "branch": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::branch.branch",
      "inversedBy": "items"
    },
    "status_history": {
      "type": "component",
      "repeatable": true,
      "component": "pos.stock-status-history"
    },
    "archived": {
      "type": "boolean",
      "default": false
    },
    "archived_at": {
      "type": "datetime"
    },
    "work_order": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::mfg-work-order.mfg-work-order",
      "inversedBy": "finished_stock_items"
    },
    "warehouse": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::warehouse.warehouse",
      "inversedBy": "stock_items"
    },
    "storage_location": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::storage-location.storage-location",
      "inversedBy": "stock_items"
    },
    "batch": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::stock-batch.stock-batch",
      "inversedBy": "stock_items"
    },
    "expiry_date": {
      "type": "date"
    }
  }
}
