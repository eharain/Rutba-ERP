{
  "kind": "collectionType",
  "collectionName": "offers",
  "info": {
    "singularName": "sale-offer",
    "pluralName": "sale-offers",
    "displayName": "Sales Offer",
    "description": "Sales promotion entity for CMS, linked to product groups, CMS pages, and categories"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "active": {
      "type": "boolean",
      "default": false
    },
    "start_date": {
      "type": "datetime"
    },
    "end_date": {
      "type": "datetime"
    },
    "description": {
      "type": "richtext"
    },
    "banner_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "discount_mode": {
      "type": "enumeration",
      "enum": [
        "none",
        "percent_off",
        "fixed_off",
        "use_product_offer_price"
      ],
      "default": "use_product_offer_price"
    },
    "discount_value": {
      "type": "decimal",
      "default": 0
    },
    "free_shipping": {
      "type": "boolean",
      "default": false
    },
    "priority": {
      "type": "integer",
      "default": 0
    },
    "product_groups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product-group.product-group",
      "inversedBy": "offers"
    },
    "cms_pages": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cms-page.cms-page",
      "inversedBy": "offers"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "offers"
    }
  }
}
