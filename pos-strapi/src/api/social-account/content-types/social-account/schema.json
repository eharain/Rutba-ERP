{
  "kind": "collectionType",
  "collectionName": "social_accounts",
  "info": {
    "singularName": "social-account",
    "pluralName": "social-accounts",
    "displayName": "Social Account",
    "description": "API credentials for connected social media platforms"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "platform": {
      "type": "enumeration",
      "enum": [
        "instagram",
        "facebook",
        "x",
        "tiktok",
        "youtube"
      ],
      "required": true
    },
    "account_name": {
      "type": "string",
      "required": true
    },
    "api_key": {
      "type": "text",
      "private": true
    },
    "api_secret": {
      "type": "text",
      "private": true
    },
    "access_token": {
      "type": "text",
      "private": true
    },
    "refresh_token": {
      "type": "text",
      "private": true
    },
    "page_id": {
      "type": "string"
    },
    "platform_user_id": {
      "type": "string"
    },
    "token_expires_at": {
      "type": "datetime",
      "private": true
    },
    "last_connected_at": {
      "type": "datetime"
    },
    "extra_config": {
      "type": "json",
      "private": true
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}
