{
  "kind": "collectionType",
  "collectionName": "notification_logs",
  "info": { "singularName": "notification-log", "pluralName": "notification-logs", "displayName": "Notification Log" },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "order": { "type": "relation", "relation": "manyToOne", "target": "api::sale-order.sale-order" },
    "template": { "type": "relation", "relation": "manyToOne", "target": "api::notification-template.notification-template" },
    "trigger_event": { "type": "string" },
    "recipient_email": { "type": "string" },
    "status": { "type": "enumeration", "enum": ["sent","failed","pending"], "default": "pending" },
    "sent_at": { "type": "datetime" },
    "error_message": { "type": "text" },
    "rendered_subject": { "type": "string" },
    "rendered_body": { "type": "text" }
  }
}
