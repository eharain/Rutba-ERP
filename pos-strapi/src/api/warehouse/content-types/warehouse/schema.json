{
  "kind": "collectionType",
  "collectionName": "warehouses",
  "info": {
    "singularName": "warehouse",
    "pluralName": "warehouses",
    "displayName": "Warehouse",
    "description": "A physical (or virtual) stock-holding location that belongs to a branch. Holds storage-locations (bins)."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "unique": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "warehouse",
        "store",
        "transit",
        "virtual",
        "supplier",
        "customer"
      ],
      "default": "warehouse"
    },
    "address": {
      "type": "text"
    },
    "is_default": {
      "type": "boolean",
      "default": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "branch": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::branch.branch",
      "inversedBy": "warehouses"
    },
    "locations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::storage-location.storage-location",
      "mappedBy": "warehouse"
    },
    "stock_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::stock-item.stock-item",
      "mappedBy": "warehouse"
    }
  }
}
