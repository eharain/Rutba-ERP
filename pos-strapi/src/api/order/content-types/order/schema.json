{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "order_id": {
      "type": "uid",
      "required": true
    },
    "customer_contact": {
      "type": "component",
      "repeatable": false,
      "component": "order.order-contact"
    },
    "products": {
      "type": "component",
      "repeatable": false,
      "component": "order.order-products"
    },
    "shipping_id": {
      "type": "string"
    },
    "rate_id": {
      "type": "string"
    },
    "shipping_name": {
      "type": "string"
    },
    "stripe_id": {
      "type": "string"
    },
    "stripe_url": {
      "type": "text"
    },
    "stripe_request": {
      "type": "json"
    },
    "stripe_response_webhook": {
      "type": "json"
    },
    "subtotal": {
      "type": "decimal"
    },
    "shipping_price": {
      "type": "decimal"
    },
    "total": {
      "type": "decimal"
    },
    "payment_status": {
      "type": "string",
      "required": true
    },
    "shipping_label": {
      "type": "json"
    },
    "tracking_url": {
      "type": "text"
    },
    "label_image": {
      "type": "text"
    },
    "tracking_code": {
      "type": "string"
    },
    "order_secret": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "owners": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "PENDING_PAYMENT",
        "PAYMENT_CONFIRMED",
        "PREPARING",
        "AWAITING_PICKUP",
        "OUT_FOR_DELIVERY",
        "DELIVERED",
        "CANCELLED",
        "FAILED_DELIVERY",
        "REFUND_INITIATED",
        "REFUNDED"
      ],
      "default": "PENDING_PAYMENT"
    },
    "delivery_method": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::delivery-method.delivery-method"
    },
    "delivery_zone": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::delivery-zone.delivery-zone"
    },
    "assigned_rider": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::rider.rider"
    },
    "delivery_cost": { "type": "decimal" },
    "delivery_cost_breakdown": { "type": "json" },
    "estimated_delivery_time": { "type": "datetime" },
    "actual_delivery_time": { "type": "datetime" },
    "rider_notes": { "type": "text" },
    "original_subtotal": { "type": "decimal" },
    "savings": { "type": "decimal" },
    "delivery_offers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::delivery-offer.delivery-offer",
      "mappedBy": "order"
    },
    "order_messages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-message.order-message",
      "mappedBy": "order"
    }
  }
}
