{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Items sold in the POS and online is a product and product variants"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": false
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "summary": {
      "type": "richtext"
    },
    "description": {
      "type": "richtext"
    },
    "sku": {
      "type": "string"
    },
    "supplierCode": {
      "type": "string"
    },
    "barcode": {
      "type": "string"
    },
    "cost_price": {
      "type": "decimal"
    },
    "offer_price": {
      "type": "decimal"
    },
    "selling_price": {
      "type": "decimal"
    },
    "tax_rate": {
      "type": "decimal"
    },
    "stock_quantity": {
      "type": "integer"
    },
    "bundle_units": {
      "type": "integer",
      "default": 1
    },
    "reorder_level": {
      "type": "integer"
    },
    "kind": {
      "type": "enumeration",
      "enum": [
        "raw_material",
        "consumable",
        "semi_finished",
        "finished_good",
        "service"
      ],
      "default": "finished_good"
    },
    "unit_of_measure": {
      "type": "enumeration",
      "enum": [
        "piece",
        "meter",
        "yard",
        "kg",
        "gram",
        "dozen",
        "set",
        "cone",
        "roll",
        "box"
      ],
      "default": "piece"
    },
    "track_mode": {
      "type": "enumeration",
      "enum": [
        "serialized",
        "bulk"
      ],
      "default": "serialized"
    },
    "bulk_quantity_on_hand": {
      "type": "decimal",
      "default": 0
    },
    "divisible": {
      "type": "boolean",
      "default": false
    },
    "sellable_quantity": {
      "type": "decimal",
      "default": 0
    },
    "is_perishable": {
      "type": "boolean",
      "default": false
    },
    "shelf_life_days": {
      "type": "integer"
    },
    "expiry_alert_days": {
      "type": "integer"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "non_returnable": {
      "type": "boolean",
      "default": false
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category"
    },
    "brands": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::brand.brand"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::stock-item.stock-item",
      "mappedBy": "product"
    },
    "purchase_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::purchase-item.purchase-item",
      "mappedBy": "product"
    },
    "owners": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "branches": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::branch.branch",
      "mappedBy": "products"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos",
        "audios"
      ]
    },
    "keywords": {
      "type": "json"
    },
    "external_ids": {
      "type": "json"
    },
    "suppliers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::supplier.supplier",
      "inversedBy": "products"
    },
    "terms": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::term.term"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "variants"
    },
    "variants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "parent"
    },
    "is_variant": {
      "type": "boolean",
      "default": false
    },
    "is_returnable": {
      "type": "boolean",
      "default": true
    },
    "is_exchangeable": {
      "type": "boolean",
      "default": true
    },
    "seo_meta": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::seo-meta.seo-meta",
      "mappedBy": "product"
    },
    "boms": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::mfg-bom.mfg-bom",
      "mappedBy": "product"
    },
    "material_lots": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::mfg-material-lot.mfg-material-lot",
      "mappedBy": "product"
    },
    "stock_levels": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::stock-level.stock-level",
      "mappedBy": "product"
    },
    "stock_batches": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::stock-batch.stock-batch",
      "mappedBy": "product"
    }
  }
}
