{
  "kind": "collectionType",
  "collectionName": "product_groups",
  "info": {
    "singularName": "product-group",
    "pluralName": "product-groups",
    "displayName": "Product Groups",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "excerpt": {
      "type": "richtext"
    },
    "content": {
      "type": "richtext"
    },
    "gallery": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product"
    },
    "layout": {
      "type": "enumeration",
      "enum": [
        "hero-slider",
        "grid-4",
        "grid-6",
        "carousel",
        "banner-single",
        "list"
      ],
      "default": "grid-4"
    },
    "priority": {
      "type": "integer",
      "default": 0
    },
    "default_sort": {
      "type": "enumeration",
      "enum": [
        "default",
        "newest",
        "price_asc",
        "price_desc"
      ],
      "default": "default"
    },
    "enable_sort_dropdown": {
      "type": "boolean",
      "default": true
    },
    "enable_view_toggle": {
      "type": "boolean",
      "default": true
    },
    "max_inline_products": {
      "type": "integer",
      "default": 12
    },
    "show_brand": {
      "type": "boolean",
      "default": true
    },
    "show_category": {
      "type": "boolean",
      "default": true
    },
    "offers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::offer.offer",
      "mappedBy": "product_groups"
    }
  }
}
