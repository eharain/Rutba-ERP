{
  "kind": "collectionType",
  "collectionName": "pay_payslips",
  "info": {
    "singularName": "pay-payslip",
    "pluralName": "pay-payslips",
    "displayName": "Payslip",
    "description": "Individual employee payslips per payroll run"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "period": {
      "type": "string"
    },
    "gross": {
      "type": "decimal"
    },
    "deductions": {
      "type": "decimal"
    },
    "net_pay": {
      "type": "decimal"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "Pending",
        "Paid"
      ],
      "default": "Pending"
    },
    "employee": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::hr-employee.hr-employee"
    },
    "payroll_run": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::pay-payroll-run.pay-payroll-run",
      "inversedBy": "payslips"
    },
    "tasks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::mfg-task.mfg-task",
      "mappedBy": "payslip"
    },
    "lines": {
      "type": "component",
      "repeatable": true,
      "component": "pay.payslip-line"
    },
    "paid_at": {
      "type": "datetime"
    },
    "payment_method": {
      "type": "enumeration",
      "enum": [
        "Cash",
        "Bank",
        "Mobile Wallet"
      ]
    },
    "bank_reference": {
      "type": "string"
    },
    "branch": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::branch.branch"
    },
    "journal_entry": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::acc-journal-entry.acc-journal-entry"
    }
  }
}
